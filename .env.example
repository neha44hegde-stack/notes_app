# Flask
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret

# Database
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/notes_app

# Optional: only needed if using the OpenAI-based summarizer instead of the local one
